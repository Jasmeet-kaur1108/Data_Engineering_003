    },
    {
      "id": "cell-code-5",
      "cell_type": "code",
      "source": "print(f'Before removing duplicates: {len(df)} rows')\nbefore = len(df)\n\n# Remove duplicate rows based on product_id\ndf = df.drop_duplicates(subset='product_id')\n\nafter = len(df)\nprint(f'After removing duplicates : {after} rows')\nprint(f'Duplicates removed        : {before - after}')",
      "metadata": {
        "trusted": true
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": "Before removing duplicates: 886 rows\nAfter removing duplicates : 886 rows\nDuplicates removed        : 0\n"
