    {
      "id": "cell-code-3a",
      "cell_type": "code",
      "source": "# Identify missing values in each column\nprint('=== MISSING VALUES PER COLUMN ===')\nmissing = df.isnull().sum()\nmissing_percent = (df.isnull().sum() / len(df)) * 100\nmissing_df = pd.DataFrame({'Missing Count': missing, 'Missing %': missing_percent})\nprint(missing_df[missing_df['Missing Count'] > 0])",
      "metadata": {
        "trusted": true
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": "=== MISSING VALUES PER COLUMN ===\n                     Missing Count  Missing %\ndiscount                       121       12.1\nwhat_customers_said            573       57.3\nseller_name                    301       30.1\nvideos                         781       78.1\nseller_information             301       30.1\nvariations                     562       56.2\n"
        }
      ],
      "execution_count": 7
    },
    {
      "id": "cell-code-3b",
      "cell_type": "code",
      "source": "# Fill missing values in 'discount' column with median\nmedian_discount = df['discount'].median()\ndf['discount'] = df['discount'].fillna(median_discount)\n\n# Fill missing 'seller_name' with 'Unknown'\ndf['seller_name'] = df['seller_name'].fillna('Unknown')\n\n# Drop rows where 'rating' is 0 (invalid rating)\ndf = df[df['rating'] > 0]\n\nprint(f'After cleaning missing values:')\nprint(f'Remaining missing values: {df.isnull().sum().sum()}')\nprint(f'Rows remaining: {len(df)}')",
      "metadata": {
        "trusted": true
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": "After cleaning missing values:\nRemaining missing values: 1999\nRows remaining: 886\n"
        }
